# ==============================================================================
# VedaAI Master Environment Variables Template
# ==============================================================================
# Copy this file to '.env' at the project root for multi-container Docker Compose config,
# or copy into 'backend/.env' and 'frontend/.env' respectively for local dev.

# ------------------------------------------------------------------------------
# Backend Service Configuration (Express Server & Queue Worker)
# ------------------------------------------------------------------------------

# The port the Express API server runs on
PORT=4000

# MongoDB Connection URI (e.g., local MongoDB or Atlas URI)
# Use 'mongodb://localhost:27017/ai-assessment' for local running
# Use 'mongodb://mongodb:27017/ai-assessment' when running in Docker Compose
MONGODB_URI=mongodb://localhost:27017/ai-assessment

# Redis Connection URL (used for BullMQ background queues)
# Use 'redis://localhost:6379' for local running
# Use 'redis://redis:6379' when running in Docker Compose
REDIS_URL=redis://localhost:6379

# OpenAI API Key (required for model inference & question generation)
# Replace with your actual OpenAI API Key starting with 'sk-...'
OPENAI_API_KEY=your_openai_api_key_here

# Origin URL of the frontend application (for CORS configuration)
FRONTEND_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# Frontend Service Configuration (Next.js Application)
# ------------------------------------------------------------------------------

# Public URL of the backend API service (accessed on the browser side)
# Use 'http://localhost:4000' for local dev or production
NEXT_PUBLIC_API_URL=http://localhost:4000

# Public URL of the backend WebSocket server for real-time progress updates
# Use 'ws://localhost:4000/ws' for local dev or production
NEXT_PUBLIC_WS_URL=ws://localhost:4000/ws
